{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SuperTerminal",
  "version": "0.1.1-alpha",
  "identifier": "local.superterminal.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SuperTerminal",
        "width": 1280,
        "height": 840,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Zemulax",
    "homepage": "https://zemulax.github.io/SuperTerminal/",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
